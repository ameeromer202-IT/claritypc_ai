# Copy this file to ".env" and adjust if needed.
#
# ClarityPC.AI talks to an Ollama server using its OpenAI-compatible API.
# Install Ollama (https://ollama.com), then: ollama pull llama3.2:3b
#
# Defaults below assume Ollama is running on the same machine.
# To use a remote/self-hosted Ollama, set the full base URL (note the /v1).
OLLAMA_BASE_URL=http://localhost:11434/v1
OLLAMA_MODEL=llama3.2:3b
